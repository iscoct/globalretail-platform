# Copy to terraform.tfvars (gitignored) and fill in YOUR values.
# Then:
#   terraform init -backend-config=backend.hcl
#   terraform plan
#   terraform apply

# --- Required (no defaults) ---------------------------------------------------
# Azure context — same values as ../../infra/terraform.tfvars.
subscription_id = ""
tenant_id       = ""

# The storage account that holds Layer 1's tfstate. Look it up in
# ../../infra/backend.hcl (line `storage_account_name`) AFTER running the
# Layer 1 bootstrap. Each developer's tfstate SA has a random suffix, so
# this cannot have a default.
layer1_tfstate_storage_account = ""

# The GitHub repo that hosts this monorepo. Must already exist on GitHub.
# The federation references the repo by name — if you fork the repo and
# apply this Terraform, set THESE values to your fork, not the upstream.
github_owner = ""   # e.g. "iscoct"
github_repo  = ""   # e.g. "globalretail-platform"

# --- Optional (all have defaults) --------------------------------------------
# workload                = "globalretail"
# environment             = "dev"
# location                = "westeurope"
# location_short          = "weu"
# owner                   = "your.name"
# github_main_branch      = "main"
# github_environment_name = "platform-prod"   # gates `terraform apply` via env protection
