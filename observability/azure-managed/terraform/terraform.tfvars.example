# Copy to terraform.tfvars (gitignored) and fill in YOUR values.
#
#   terraform init -backend-config=backend.hcl
#   terraform plan
#   terraform apply

# --- Required -----------------------------------------------------------
subscription_id = ""
tenant_id       = ""

# Copy from ../../../infra/backend.hcl after Layer 1 bootstrap.
layer1_tfstate_storage_account = ""

# --- Optional but recommended -------------------------------------------
# Object ID of the Entra ID user who logs into Managed Grafana as admin.
# Find with: az ad signed-in-user show --query id -o tsv
grafana_admin_user_object_id = ""

# --- Optional (defaults are fine) ---------------------------------------
# workload            = "globalretail"
# environment         = "dev"
# location            = "westeurope"
# location_short      = "weu"
# owner               = "platform-team"
# managed_grafana_sku = "Essential"   # or "Standard" for SLA + autoscale
